# MicroStrategy Connection Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — NEVER commit real credentials.
#
# Variable resolution order (for every setting):
#   1. MSTR_{ENV}_{SETTING}   — environment-specific override
#   2. MSTR_{SETTING}         — shared fallback / single-environment value
#   3. Built-in default       — safe fallback (where applicable)
#
# Example: when MSTR_ENV=qa, MSTR_QA_BASE_URL is used before MSTR_BASE_URL.
#
# Passwords can be stored in the OS keyring instead of this file — see the
# Keyring section at the bottom.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment Selection ─────────────────────────────────────────────────────
#
# Active environment: dev | qa | prod  (default: dev)
# When set, MSTR_{ENV}_* variables take precedence over bare MSTR_* variables.
MSTR_ENV=dev


# ═════════════════════════════════════════════════════════════════════════════
# OPTION A — Single-environment setup
# ─────────────────────────────────────────────────────────────────────────────
# Fill only these bare variables and set MSTR_ENV=dev.
# Skip the per-environment sections (Option B) entirely.
# ═════════════════════════════════════════════════════════════════════════════

# ── Required connection settings ─────────────────────────────────────────────

MSTR_BASE_URL=https://yourserver.cloud.microstrategy.com/MicroStrategyLibrary
MSTR_USERNAME=your.username@company.com
# Leave MSTR_PASSWORD blank to use the OS keyring (see Keyring section below).
MSTR_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────

# Login mode: 1=Standard, 16=SAML, 64=LDAP  (default: 1)
MSTR_LOGIN_MODE=1

# ── Project defaults (optional) ───────────────────────────────────────────────

# Set either PROJECT_ID (preferred) or PROJECT_NAME.
# Scripts can always override per-session with session.set_project().
MSTR_PROJECT_ID=
MSTR_PROJECT_NAME=

# Platform Analytics project GUID (scripts that write metadata to PA).
MSTR_PA_PROJECT_ID=

# Platform Analytics dataset/cube GUID (script-specific; see mstrDocumentObjectDefinition.py).
MSTR_PA_DATASET_ID=

# ── Output & logging ─────────────────────────────────────────────────────────

# Default directory for CSV/Excel output (default: c:/tmp)
MSTR_OUTPUT_DIR=c:/tmp

# Directory for rotating log files (default: logs)
MSTR_LOG_DIR=logs

# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
MSTR_LOG_LEVEL=INFO


# ═════════════════════════════════════════════════════════════════════════════
# OPTION B — Multi-environment setup (dev / qa / prod)
# ─────────────────────────────────────────────────────────────────────────────
# Define per-environment variables below. Set MSTR_ENV to switch environments
# without changing any code. The bare MSTR_* variables above serve as a
# shared fallback for any setting not overridden per environment.
#
# Every MSTR_* setting supports a per-environment prefix:
#   MSTR_{ENV}_BASE_URL, MSTR_{ENV}_USERNAME, MSTR_{ENV}_PASSWORD,
#   MSTR_{ENV}_LOGIN_MODE, MSTR_{ENV}_PROJECT_ID, MSTR_{ENV}_PROJECT_NAME,
#   MSTR_{ENV}_PA_PROJECT_ID, MSTR_{ENV}_PA_DATASET_ID,
#   MSTR_{ENV}_OUTPUT_DIR, MSTR_{ENV}_LOG_DIR, MSTR_{ENV}_LOG_LEVEL
# ═════════════════════════════════════════════════════════════════════════════

# ── Dev ───────────────────────────────────────────────────────────────────────
# Active when MSTR_ENV=dev (or when MSTR_ENV is not set).

MSTR_DEV_BASE_URL=https://dev.cloud.microstrategy.com/MicroStrategyLibrary
MSTR_DEV_USERNAME=your.username@company.com
# Leave blank to use the OS keyring (see Keyring section).
MSTR_DEV_PASSWORD=

# Uncomment to override shared defaults for dev only:
# MSTR_DEV_LOGIN_MODE=1
# MSTR_DEV_PROJECT_ID=
# MSTR_DEV_PROJECT_NAME=
# MSTR_DEV_PA_PROJECT_ID=
# MSTR_DEV_PA_DATASET_ID=
# MSTR_DEV_OUTPUT_DIR=c:/tmp/dev
# MSTR_DEV_LOG_DIR=logs/dev
# MSTR_DEV_LOG_LEVEL=DEBUG

# ── QA ────────────────────────────────────────────────────────────────────────
# Active when MSTR_ENV=qa.

MSTR_QA_BASE_URL=https://qa.cloud.microstrategy.com/MicroStrategyLibrary
MSTR_QA_USERNAME=your.username@company.com
# Leave blank to use the OS keyring (see Keyring section).
MSTR_QA_PASSWORD=

# Uncomment to override shared defaults for QA only:
# MSTR_QA_LOGIN_MODE=1
# MSTR_QA_PROJECT_ID=
# MSTR_QA_PROJECT_NAME=
# MSTR_QA_PA_PROJECT_ID=
# MSTR_QA_PA_DATASET_ID=
# MSTR_QA_OUTPUT_DIR=c:/tmp/qa
# MSTR_QA_LOG_DIR=logs/qa
# MSTR_QA_LOG_LEVEL=INFO

# ── Prod ──────────────────────────────────────────────────────────────────────
# Active when MSTR_ENV=prod.

MSTR_PROD_BASE_URL=https://prod.cloud.microstrategy.com/MicroStrategyLibrary
MSTR_PROD_USERNAME=your.username@company.com
# Leave blank to use the OS keyring (see Keyring section).
MSTR_PROD_PASSWORD=

# Uncomment to override shared defaults for prod only:
# MSTR_PROD_LOGIN_MODE=1
# MSTR_PROD_PROJECT_ID=
# MSTR_PROD_PROJECT_NAME=
# MSTR_PROD_PA_PROJECT_ID=
# MSTR_PROD_PA_DATASET_ID=
# MSTR_PROD_OUTPUT_DIR=c:/tmp/prod
# MSTR_PROD_LOG_DIR=logs/prod
# MSTR_PROD_LOG_LEVEL=WARNING


# ═════════════════════════════════════════════════════════════════════════════
# OS KEYRING — Password-free credential storage (recommended)
# ─────────────────────────────────────────────────────────────────────────────
# Store passwords in your OS credential store instead of in this file.
# Supported backends: Windows Credential Manager, macOS Keychain, SecretService.
#
# Install the keyring package (already in requirements.txt, uncomment to use):
#   pip install keyring
#
# How it works:
#   If MSTR_*_PASSWORD (or MSTR_PASSWORD) is absent or blank, MstrConfig
#   automatically tries keyring.get_password(service, username).
#   No code changes needed — just leave the password variables empty above.
#
# Keyring service name (optional — defaults to "mstrio"):
#   MSTR_KEYRING_SERVICE=mstrio
#
# Per-environment overrides (e.g. keep dev/qa/prod in separate keyring entries):
#   MSTR_DEV_KEYRING_SERVICE=mstrio-dev
#   MSTR_QA_KEYRING_SERVICE=mstrio-qa
#   MSTR_PROD_KEYRING_SERVICE=mstrio-prod
#
# ── Store a password ─────────────────────────────────────────────────────────
#
#   Single-env or shared:
#     python -m keyring set mstrio your.username@company.com
#
#   Per-environment (recommended for multi-env setups):
#     python -m keyring set mstrio-dev  your.username@company.com
#     python -m keyring set mstrio-qa   your.username@company.com
#     python -m keyring set mstrio-prod your.username@company.com
#
# ── Verify a stored password ─────────────────────────────────────────────────
#
#     python -m keyring get mstrio your.username@company.com
#
# ── Delete a stored password ─────────────────────────────────────────────────
#
#     python -m keyring del mstrio your.username@company.com
#
# ── Override the service name ────────────────────────────────────────────────
# Uncomment and change these if you want a custom keyring service name.
# The per-env prefix is checked first (MSTR_QA_KEYRING_SERVICE → MSTR_KEYRING_SERVICE).

# MSTR_KEYRING_SERVICE=mstrio
# MSTR_DEV_KEYRING_SERVICE=mstrio-dev
# MSTR_QA_KEYRING_SERVICE=mstrio-qa
# MSTR_PROD_KEYRING_SERVICE=mstrio-prod
