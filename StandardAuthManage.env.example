# StandardAuthManage.py — Script-specific configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to StandardAuthManage.env and fill in the group GUID.
# StandardAuthManage.env is NOT committed to the repo.
# ─────────────────────────────────────────────────────────────────────────────

# GUID of the user group that grants standard authentication.
# Users NOT in this group (recursively) will have standard_auth disabled.
# Can be overridden at runtime via --group-id.
STANDARD_AUTH_GROUP_ID=

# ── Concurrency ──────────────────────────────────────────────────────────────
# Number of concurrent threads for fetching user details and applying changes.
# list_users() returns lightweight objects; each user must be fetched
# individually via User(conn, id=...) to read standard_auth.  Higher values
# speed up large environments but increase server load.
# Can be overridden at runtime via --concurrency.
CONCURRENCY=10

# ── Last-run timestamps (managed automatically by --apply) ───────────────────
# These are written by the script when --apply completes successfully.
# Used by --since-last-run to filter users by date_modified.
# You may edit or clear these manually if needed.
# LAST_RUN_DEV=
# LAST_RUN_QA=
# LAST_RUN_PROD=
